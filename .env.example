# Copy this file to .env for local development, and add the same
# two values as Environment Variables in your Vercel project settings.
#
# Find both values in your Supabase project:
# Project Settings -> API

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run the one-time data migration script
# (scripts/migrate.mjs). Find it in: Project Settings -> API -> service_role key.
# NEVER put this key in .env.example values that get committed, never expose it
# in frontend code, and never commit your real .env file.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
